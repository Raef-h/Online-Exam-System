<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="server.ServerController"
      prefWidth="700" prefHeight="400">

    <MenuBar>
        <Menu text="New Exam">
            <MenuItem text="Create New Exam" onAction="#handleNewExamMenu"/>
        </Menu>
        <Menu text="Help">
            <MenuItem text="About" onAction="#handleHelp"/>
        </Menu>
    </MenuBar>

    <TableView fx:id="examTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName"  text="Exam Name"  prefWidth="150"/>
            <TableColumn fx:id="colTime"  text="Start Date/Time" prefWidth="150"/>
            <TableColumn fx:id="colActive" text="Active Students"  prefWidth="120"/>
            <TableColumn fx:id="colComplete" text="Completed Students"  prefWidth="130"/>
            <TableColumn fx:id="colStatus" text="Status"  prefWidth="100"/>
        </columns>
        <placeholder><Label text="No content in table"/></placeholder>
    </TableView>

</VBox>
