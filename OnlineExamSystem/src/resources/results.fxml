<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="server.ResultsController"
      prefWidth="600" prefHeight="400" spacing="10">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <Label text="All Exam Results" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colStudent" text="Student ID" prefWidth="120"/>
            <TableColumn fx:id="colCourse"  text="Course Name" prefWidth="150"/>
            <TableColumn fx:id="colYear"    text="Year" prefWidth="80"/>
            <TableColumn fx:id="colSemester" text="Semester" prefWidth="100"/>
            <TableColumn fx:id="colScore"    text="Score" prefWidth="100"/>
        </columns>
        <placeholder><Label text="No results found in database."/></placeholder>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button text="Close" onAction="#handleClose"/>
    </HBox>
</VBox>
