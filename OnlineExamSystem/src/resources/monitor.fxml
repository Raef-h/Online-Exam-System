<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="server.MonitorController"
      spacing="12" styleClass="root-pane">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="🔍 Real-time Student Monitor" styleClass="app-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="totalLabel" text="Active Students: 0" styleClass="section-header"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colStudent"  text="Student ID" prefWidth="160"/>
            <TableColumn fx:id="colExam"     text="Exam"         prefWidth="180"/>
            <TableColumn fx:id="colProgress" text="Progress"     prefWidth="100"/>
            <TableColumn fx:id="colScore"    text="Score"        prefWidth="80"/>
            <TableColumn fx:id="colIp"       text="IP"           prefWidth="130"/>
        </columns>
        <placeholder><Label text="No students connected." styleClass="placeholder-label"/></placeholder>
    </TableView>
</VBox>
