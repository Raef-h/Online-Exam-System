<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.ModeSelectionController"
      alignment="CENTER" spacing="20">
    <padding><Insets top="20" right="40" bottom="40" left="40"/></padding>
    
    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="langBtn" text="%btn.lang" onAction="#handleToggleLang"/>
    </HBox>
    
    <Button fx:id="serverBtn" text="%btn.server" onAction="#handleStartServer"
            prefWidth="400" prefHeight="100" style="-fx-font-size: 16px;"/>
            
    <Button fx:id="clientBtn" text="%btn.client" onAction="#handleJoinExam"
            prefWidth="400" prefHeight="100" style="-fx-font-size: 16px;"/>
</VBox>
