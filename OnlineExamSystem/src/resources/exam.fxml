<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="client.ExamController"
      alignment="CENTER" spacing="30">
    <padding><Insets top="50" right="50" bottom="50" left="50"/></padding>

    <HBox spacing="100" alignment="CENTER">
        <Label fx:id="counterLabel" text="Question 0/0" style="-fx-font-weight: bold;"/>
        <Label fx:id="timerLabel" text="Time Left: 00:00" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
    </HBox>

    <Label fx:id="questionLabel" text="Question text here" wrapText="true" maxWidth="400" style="-fx-font-size: 14px;"/>

    <VBox fx:id="mcqBox" spacing="10" alignment="CENTER_LEFT" maxWidth="200">
        <RadioButton fx:id="rbA" text="Choice A"/>
        <RadioButton fx:id="rbB" text="Choice B"/>
        <RadioButton fx:id="rbC" text="Choice C"/>
        <RadioButton fx:id="rbD" text="Choice D"/>
    </VBox>

    <VBox fx:id="tfBox" spacing="10" alignment="CENTER_LEFT" maxWidth="200">
        <RadioButton fx:id="rbTrue" text="TRUE"/>
        <RadioButton fx:id="rbFalse" text="FALSE"/>
    </VBox>

    <Region prefHeight="20"/>
    <Button fx:id="nextBtn" text="Next" onAction="#handleNext"/>
    <Label fx:id="errorLabel" textFill="red"/>
</VBox>
